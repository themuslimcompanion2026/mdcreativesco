# =====================================================
# MD Creatives — Environment Variables
# Copy to .env (local) or configure in Cloudflare dashboard
# (Workers & Pages → Settings → Variables and Secrets)
# =====================================================

# ---- Supabase (client + server) ----
# Public values — safe to expose in the browser bundle
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Mirror values used by server functions / SSR (process.env)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"

# Server-only — NEVER expose. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ---- Wise (payments) ----
WISE_API_TOKEN="your-wise-api-token"
WISE_PROFILE_ID="your-wise-profile-id"
# PEM public key used to verify incoming Wise webhook signatures
WISE_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ---- Lovable AI Gateway (optional, only if AI features are used) ----
LOVABLE_API_KEY="provisioned-by-lovable-or-leave-unset"
